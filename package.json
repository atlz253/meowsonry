{
  "name": "meowsonry-layout",
  "description": "Masonry layout package",
  "version": "0.0.0",
  "license": "MIT",
  "author": "Fedor Alekseev",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test.playwright": "npx playwright test --grep-invert @bundle",
    "test.playwright.update": "playwright test --grep-invert @bundle --update-snapshots",
    "test.playwright.bundle": "npx playwright test --grep @bundle",
    "test.playwright.bundle.update": "npx playwright test --grep @bundle --update-snapshots",
    "test.playwright.ui": "playwright test --ui",
    "test.server": "vite --config tests/e2e/vite/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "lint.fix": "eslint src --ext ts --fix",
    "build": "vite build",
    "prepare": "npm run build",
    "prepublishOnly": "npm test"
  },
  "exports": {
    ".": "./src/index.ts",
    "./dist/meowsonry-layout.iife.js": "./dist/my-lib.iife.min.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "masonry",
    "layout",
    "grid"
  ],
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@cloudfour/simple-svg-placeholder": "^1.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.3",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.3.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.0.18"
  }
}
